    warrantyRows.forEach((row, index) => {
      const source = String(row[ONLINER_PRINT_COLUMNS.SOURCE] || '').toLowerCase();
      const templateBody = (source.includes('tuf') ? templates.TUF : templates.INOTE).getBody();
      const startIndex = body.getNumChildren();

      appendTemplateContent(body, templateBody);

      const endIndex = body.getNumChildren() - 1;
      const dateValue = row[ONLINER_PRINT_COLUMNS.DATE_DELIVERY];
      const deliveryDate = dateValue instanceof Date
        ? Utilities.formatDate(dateValue, 'GMT+03', 'dd.MM.yyyy')
        : dateValue;

      const acValue = parseInt(row[ONLINER_PRINT_COLUMNS.WARRANTY_BASE], 10);
      const aiValue = parseInt(row[ONLINER_PRINT_COLUMNS.WARRANTY_FULL], 10);
      const finalPrice = parsePrice(row[ONLINER_PRINT_COLUMNS.SALE_PRICE]);
      const orderNumber = String(row[ONLINER_PRINT_COLUMNS.ORDER_NUMBER] || '').trim();

      if (orderNumber) {
        orderNumbers.push(orderNumber);
      }

      const replacements = {
        '{Дата}': deliveryDate || '',
        '{Модель}': row[ONLINER_PRINT_COLUMNS.MODEL] || '',
        '{Цена продажи}': formatByrAmount(finalPrice, ' '),
        '{Гарантия}': buildWarrantyText(acValue, aiValue),
        '{Номер заказа}': orderNumber
      };

      for (let i = startIndex; i <= endIndex; i++) {
        replaceInDocumentElement(body.getChild(i), replacements);
      }

      if (index < warrantyRows.length - 1) {
        body.appendPageBreak();
      }
    });

    mergedDoc.saveAndClose();
    Object.values(templates).forEach(doc => doc.saveAndClose());

    const modelsSummary = checksRows.map(mapRowToCheckSummary);
    const checksSpreadsheet = createChecksSpreadsheetInFolder(
      OUTPUT_FOLDER_ID,
      checksFileName,
      modelsSummary
    );

    if (sendOrderNumbers && orderNumbers.length) {
      const ordersText = `📋 Номера заказов:\n${orderNumbers.map((num, idx) => `${idx + 1}. ${num}`).join('\n')}`;
      sendMessage(ordersText, null, CONFIG.CHAT_ID_PERSONAL, CONFIG.SEND_MODE.FAST, null, { markdown: false });
    }

    sendMessage(
      `Гарантийные талоны\n${mergedFile.getUrl()}`,
      null,
      CONFIG.CHAT_ID_PERSONAL,
      CONFIG.SEND_MODE.FAST,
      null,
      { markdown: false }
    );

    sendMessage(
      `Чеки\n${checksSpreadsheet.getUrl()}`,
      null,
      CONFIG.CHAT_ID_PERSONAL,
      CONFIG.SEND_MODE.FAST,
      null,
      { markdown: false }
    );

    if (notifyUi && ui) {
      ui.alert('✅ Готово', 'Ссылки на гарантийные талоны и чеки отправлены в личный Telegram.', ui.ButtonSet.OK);
    }
  } catch (error) {
    if (notifyUi && ui) {
      ui.alert('❌ Ошибка', error.message, ui.ButtonSet.OK);
    }
    throw error;
  }
}

function normalizeSupplierName(name) {
  if (!name && name !== 0) return '';
  return String(name).trim().toLowerCase().replace(/\s+/g, '').replace(/[^0-9a-zа-яё]/gi, '');
}

function getToday() { return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'dd.MM.yyyy'); }

function normalizeSheetDate(value) {
  if (value instanceof Date) {
    return Utilities.formatDate(value, Session.getScriptTimeZone(), 'dd.MM.yyyy');
  }

  const raw = String(value || '').trim();
  if (!raw) return '';

  const dateMatch = raw.match(/(\d{1,2})[\.\/\-](\d{1,2})[\.\/\-](\d{4})/);
  if (!dateMatch) return raw;

  const [, day, month, year] = dateMatch;
  return `${String(day).padStart(2, '0')}.${String(month).padStart(2, '0')}.${year}`;
}

function getTodayOrderRows() {
  if (Object.keys(COL_IDX).length === 0) {
    initColumns();
  }

  const ordersSheet = getSpreadsheet().getSheetByName(CONFIG.SHEETS.ORDERS);

  if (!ordersSheet) {
    throw new Error('❌ Не найдена таблица "Заказы"');
  }

  const lastRow = ordersSheet.getLastRow();
  if (lastRow < 3) return [];

  const lastColumn = ordersSheet.getLastColumn();
  const data = ordersSheet.getRange(3, 1, lastRow - 2, lastColumn).getValues();
  const today = getToday();
  const rows = [];

  data.forEach((row, i) => {
    const realRow = i + 3;
    const rowDate = normalizeSheetDate(
      row[COL_IDX.DATE_ORDER] || row[COL_IDX.DATE]
    );
    if (rowDate !== today) return;

    const orderNum = String(row[COL_IDX.ORDER_NUM] || '').trim();
    const model = String(row[COL_IDX.MODEL] || '').trim();
    const supplier = String(row[COL_IDX.SUPPLIER] || '').trim();
    const client = String(row[COL_IDX.CLIENT] || '').trim();
    const address = String(row[COL_IDX.ADDRESS] || '').trim();

    if (!orderNum && !model && !supplier && !client && !address) return;

    rows.push({ rowIndex: realRow, row });
  });

  console.log(`📅 Найдено заказов на сегодня (${today}): ${rows.length}`);
  return rows;
}

function notifyTodayOrdersToPersonal(rows) {
  if (!CONFIG.CHAT_ID_PERSONAL) return;

  const orderNumbers = [...new Set(
    rows
      .map(({ row }) => String(row[COL_IDX.ORDER_NUM] || '').trim())
      .filter(Boolean)
  )];

  if (!orderNumbers.length) return;

  const text = `📋 Номера заказов на ${getToday()} (${orderNumbers.length}):\n` +
               orderNumbers.map((num, index) => `${index + 1}. ${num}`).join('\n');

  sendMessage(text, null, CONFIG.CHAT_ID_PERSONAL, CONFIG.SEND_MODE.FAST, null, { markdown: false });
}

function collectSuppliersFromRows(rows) {
  const supplierGroups = {};

  rows.forEach(({ row }) => {
    const supName = String(row[COL_IDX.SUPPLIER] || '').trim();
    if (!supName) return;

    const supNorm = normalizeSupplierName(supName);
    if (!supplierGroups[supNorm]) {
      supplierGroups[supNorm] = {
        name: supName,
        items: []
      };
    }

    supplierGroups[supNorm].items.push({ model: row[COL_IDX.MODEL] });
  });

  return supplierGroups;
}

function cleanAddress(addr) {
  return String(addr || '').replace(/\(.*?\)/g, '').replace(/\s+/g, ' ').replace(/[,;]+/g, ',').trim();
}

