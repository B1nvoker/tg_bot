  console.log(`   • Размер: ${(propsSize / 1024).toFixed(2)} KB`);
  console.log(`   • Лимит: ~500 KB`);
  console.log(`   • Использовано: ${((propsSize / 500000) * 100).toFixed(1)}%`);

  // Уведомление если превышаем 70%
  if (propsSize > 350000 && CONFIG.DEBUG) {
