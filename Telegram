// 🔥 ОБНОВЛЕННЫЙ setWithTTL С ПРИОРИТЕТАМИ
function setWithTTL(key, value, min, useCache = false) {
  const ttlMs = Date.now() + min * 60000;

  if (useCache && min <= 120) { // CacheService для короткоживущих данных (до 2 часов)
    try {
      const cacheKey = `cache_${key}`;
      CACHE.put(cacheKey, JSON.stringify(value), min * 60);
      // Дублируем в ScriptProperties для резерва
      scriptProps.setProperty(key, JSON.stringify(value));
      scriptProps.setProperty(`ttl_${key}`, String(ttlMs));
    } catch (e) {
      // Fallback на ScriptProperties
      console.warn(`CacheService failed for ${key}, using ScriptProperties`);
      scriptProps.setProperty(key, JSON.stringify(value));
      scriptProps.setProperty(`ttl_${key}`, String(ttlMs));
    }
  } else {
    // ScriptProperties для долгоживущих данных
    scriptProps.setProperty(key, JSON.stringify(value));
    scriptProps.setProperty(`ttl_${key}`, String(ttlMs));
  }
}

// 🔥 ОБНОВЛЕННЫЙ getWithTTL С ПРОВЕРКОЙ TTL ДЛЯ CACHE
function getWithTTL(key) {
  // 1. Проверяем TTL в ScriptProperties (главный источник истины)
  const ttl = scriptProps.getProperty(`ttl_${key}`);
  const val = scriptProps.getProperty(key);

  // Если TTL истек - удаляем ВСЕ следы и возвращаем null
  if (ttl && Date.now() > Number(ttl)) {
    scriptProps.deleteProperty(key);
    scriptProps.deleteProperty(`ttl_${key}`);

    try {
      CACHE.remove(`cache_${key}`);
      CACHE.remove(key);
    } catch (e) {
      // Игнорируем ошибки CacheService
    }

    return null;
  }

  // Если TTL/данные в Properties уже удалены, не даем CacheService вернуть устаревшее значение
  if (!ttl && !val) {
    try {
      CACHE.remove(`cache_${key}`);
      CACHE.remove(key);
    } catch (e) {
      // Игнорируем ошибки CacheService
    }
    return null;
  }

  // 2. Пробуем CacheService, но только если TTL актуален
  try {
    const cacheKeys = [`cache_${key}`, key];
    for (const cacheKey of cacheKeys) {
      const cached = CACHE.get(cacheKey);
      if (cached) {
        return JSON.parse(cached);
      }
    }
  } catch (e) {
    // Игнорируем ошибки CacheService
  }

  // 3. Fallback на ScriptProperties
  return val ? JSON.parse(val) : null;
}

// 🔥 УЛУЧШЕННАЯ ОЧИСТКА СТАРЫХ СВОЙСТВ
function cleanupOldProperties() {
  const allProps = scriptProps.getProperties();
  const now = Date.now();
  let deletedCount = 0;
  let errorCount = 0;

  console.log(`🧹 Начинаю очистку свойств. Всего ключей: ${Object.keys(allProps).length}`);

  for (const key in allProps) {
    if (key.startsWith('ttl_')) {
      try {
        const ttl = Number(allProps[key]);
        if (ttl && now > ttl) {
          const dataKey = key.replace('ttl_', '');

          // 🔥 УДАЛЯЕМ ОСНОВНОЙ КЛЮЧ И TTL
          scriptProps.deleteProperty(dataKey);
          scriptProps.deleteProperty(key);

          // 🔥 УДАЛЯЕМ ИЗ CACHESERVICE
          try {
            CACHE.remove(`cache_${dataKey}`);
          } catch (e) {
            // Игнорируем ошибки CacheService
          }

          deletedCount++;

          // 🔥 ЛОГИРОВАНИЕ КАЖДЫЕ 50 КЛЮЧЕЙ
          if (deletedCount % 50 === 0) {
            console.log(`🧹 Очищено ${deletedCount} ключей...`);
          }
        }
      } catch (error) {
        console.error(`❌ Ошибка при обработке ключа ${key}:`, error);
        errorCount++;
      }
    }
  }

  console.log(`🧹 Очистка свойств завершена: удалено ${deletedCount} ключей, ошибок: ${errorCount}`);

  // 🔥 УВЕДОМЛЕНИЕ В ТЕЛЕГРАМ (только в DEBUG)
  if (CONFIG.DEBUG && deletedCount > 0) {
    const msg = `🧹 Очистка старых свойств завершена\n` +
               `Удалено ключей: ${deletedCount}\n` +
               `Ошибок: ${errorCount}\n` +
               `Осталось ключей: ${Object.keys(scriptProps.getProperties()).length}`;

    sendMessage(msg, null, CONFIG.CHAT_ID, CONFIG.SEND_MODE.FAST, null, { markdown: false });
  }

  return { deleted: deletedCount, errors: errorCount, remaining: Object.keys(scriptProps.getProperties()).length };
}

function mdSafe(text) {
  if (text === null || text === undefined) return '';
  const str = String(text);
  return str.replace(/([_*[\]()~`>#+\-=|{}.!])/g, '\\$1');
}

// Возвращаем число как число, чтобы Sheets мог считать суммы
function formatNumber(num) {
  if (num === '' || num === null || isNaN(num)) return '';
  return Number(num);
}

function formatPriceForDisplay(num) {
  if (num === '' || num === null || num === undefined) return '0,00';
  // Если это строка, то преобразуем в число, используя parsePrice
  const number = typeof num === 'string' ? parsePrice(num) : Number(num);
  if (isNaN(number)) return '0,00';
  // Форматируем с двумя знаками после запятой
  return number.toFixed(2).replace('.', ',');
}


function parsePrice(text) {
  if (typeof text === 'number') return text;
  const clean = String(text || '').replace(',', '.').replace(/[^\d.]/g, '');
  return Number(clean) || 0;
}

function formatByrAmount(value, separator = ' ') {
  if (value === null || value === undefined || value === '') return '';

  const amount = typeof value === 'string' ? parsePrice(value) : Number(value);
  if (isNaN(amount)) return '';

  const [integer, decimal] = Math.abs(amount).toFixed(2).split('.');
  const sign = amount < 0 ? '-' : '';

  const formattedInteger = integer
    .split('')
    .reverse()
    .join('')
    .replace(/(\d{3})(?=\d)/g, `$1${separator}`)
    .split('')
    .reverse()
    .join('');

  return `${sign}${formattedInteger},${decimal}`;
}

function pluralizeMonthsForWarranty(n) {
  if (n % 10 === 1 && n % 100 !== 11) return 'месяц';
  if ([2, 3, 4].includes(n % 10) && ![12, 13, 14].includes(n % 100)) return 'месяца';
  return 'месяцев';
}

function replaceInDocumentElement(element, replacements) {
  const elementType = element.getType();

  if (elementType === DocumentApp.ElementType.PARAGRAPH) {
    const paragraph = element.asParagraph();
    Object.keys(replacements).forEach(key => {
      const pattern = key.replace(/[{}]/g, '\\$&');
      paragraph.replaceText(pattern, String(replacements[key]));
    });
    return;
  }

  if (elementType === DocumentApp.ElementType.TABLE) {
    const table = element.asTable();
    for (let row = 0; row < table.getNumRows(); row++) {
      const tableRow = table.getRow(row);
      for (let cell = 0; cell < tableRow.getNumCells(); cell++) {
        const tableCell = tableRow.getCell(cell);
        for (let i = 0; i < tableCell.getNumChildren(); i++) {
          const child = tableCell.getChild(i);
          if (child.getType() === DocumentApp.ElementType.PARAGRAPH) {
            replaceInDocumentElement(child, replacements);
          }
        }
      }
    }
  }
}

function copyAndProcessTemplate(templateId, folderId, fileName) {
  const templateFile = DriveApp.getFileById(templateId);
  const targetFolder = DriveApp.getFolderById(folderId);
  const copiedFile = templateFile.makeCopy(fileName, targetFolder);
  const copiedDoc = DocumentApp.openById(copiedFile.getId());
  return { file: copiedFile, doc: copiedDoc };
}

function buildWarrantyText(acValue, aiValue) {
  function buildFromAC(value) {
    if (isNaN(value) || value <= 0) return null;
    if (value < 36) {
      const serviceMonths = 36 - value;
      return `${value} ${pluralizeMonthsForWarranty(value)} + ${serviceMonths} ${pluralizeMonthsForWarranty(serviceMonths)} сервисного обслуживания`;
    }
    return `${value} ${pluralizeMonthsForWarranty(value)}`;
  }

  function buildFromAI(value) {
    if (isNaN(value) || value <= 0) return null;
    const base = 12;
    const serviceMonths = Math.max(value - base, 0);
    return serviceMonths > 0
      ? `${base} ${pluralizeMonthsForWarranty(base)} + ${serviceMonths} ${pluralizeMonthsForWarranty(serviceMonths)} сервисного обслуживания`
      : `${base} ${pluralizeMonthsForWarranty(base)}`;
  }

  if (!isNaN(acValue) && acValue > 0) return buildFromAC(acValue);
  if (!isNaN(aiValue) && aiValue > 0) return buildFromAI(aiValue);
  return `12 ${pluralizeMonthsForWarranty(12)} + 24 ${pluralizeMonthsForWarranty(24)} сервисного обслуживания`;
}

function appendTemplateContent(targetBody, templateBody) {
  for (let i = 0; i < templateBody.getNumChildren(); i++) {
    const element = templateBody.getChild(i).copy();
    const elementType = element.getType();

    switch (elementType) {
      case DocumentApp.ElementType.PARAGRAPH:
        targetBody.appendParagraph(element.asParagraph());
        break;
      case DocumentApp.ElementType.TABLE:
        targetBody.appendTable(element.asTable());
        break;
      case DocumentApp.ElementType.INLINE_IMAGE:
        targetBody.appendImage(element.asInlineImage());
        break;
      case DocumentApp.ElementType.LIST_ITEM:
        targetBody.appendListItem(element.asListItem());
        break;
      default:
        targetBody.appendParagraph(element.getText ? element.getText() : '');
    }
  }
}

function createChecksSpreadsheetInFolder(folderId, fileName, modelsSummary) {
  const spreadsheet = SpreadsheetApp.create(fileName);
  const file = DriveApp.getFileById(spreadsheet.getId());
  const folder = DriveApp.getFolderById(folderId);
  file.moveTo(folder);

  const sheet = spreadsheet.getSheets()[0];
  sheet.setName('Чеки');

  const rows = [['Модель', 'Цена']];
  modelsSummary
    .sort((a, b) => a.price - b.price)
    .forEach(item => rows.push([item.model, item.formattedPrice]));

  sheet.getRange(1, 1, rows.length, 2).setValues(rows);
  sheet.autoResizeColumns(1, 2);

  return spreadsheet;
}

function buildPrintRowsForToday(baseRows) {
  const rows = baseRows.map(item => item.row);
  if (rows.length % 2 === 0) return rows;

  const ordersSheet = getSpreadsheet().getSheetByName(CONFIG.SHEETS.ORDERS);

  const nextRowIndex = baseRows[baseRows.length - 1].rowIndex + 1;
  if (nextRowIndex > ordersSheet.getLastRow()) {
    throw new Error('Не удалось добавить следующую строку для четного количества гарантийных талонов');
  }

  const nextRow = ordersSheet.getRange(nextRowIndex, 1, 1, ordersSheet.getLastColumn()).getValues()[0];
  rows.push(nextRow);
  return rows;
}

function mapRowToCheckSummary(row) {
  const price = parsePrice(row[ONLINER_PRINT_COLUMNS.SALE_PRICE]);
  return {
    model: row[ONLINER_PRINT_COLUMNS.MODEL] || '',
    price,
    formattedPrice: formatByrAmount(price, ' ')
  };
}

